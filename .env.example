# Environment template - copy to .env and configure for your setup

# === Server configuration ===
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8010
MCP_HOST=127.0.0.1
MCP_PORT=3001

# === Model serving strategy ===
# Options: local-default, local-onestack, server
ENGINE_PROFILE=local-default

# === VLM (Vision-Language Model) ===
# Defaults to native Ollama — the recommended, verified path (`ollama pull qwen2.5vl`).
# For llama.cpp instead: VLM_URL=http://127.0.0.1:8080 and
# VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct-GGUF
VLM_URL=http://127.0.0.1:11434
VLM_MODEL=qwen2.5vl
VLM_TIMEOUT_S=60.0
VLM_MAX_RETRIES=3
# Per-frame generation cap (the JSON is small); the focused error retry gets more
# room for long stack traces.
VLM_MAX_TOKENS=768
VLM_ERROR_MAX_TOKENS=1024
# Keyframes analyzed concurrently. Local single-GPU servers serialize internally;
# raise only when the engine is set up for parallelism (Ollama OLLAMA_NUM_PARALLEL
# / llama.cpp --parallel).
VLM_MAX_CONCURRENCY=3
# Request OpenAI-style JSON output (response_format). Set false for an engine that
# rejects the field.
VLM_JSON_MODE=true
# Send frames as JPEG (smaller upload + fewer vision tokens). Stored keyframes
# remain lossless PNG.
VLM_SEND_JPEG=true
VLM_JPEG_QUALITY=85

# === Coder model ===
CODER_URL=http://127.0.0.1:11434
CODER_MODEL=qwen2.5-coder:7b
CODER_TIMEOUT_S=120.0
CODER_MAX_RETRIES=2

# === Classification and routing ===
CLASSIFY_CONFIDENCE_THRESHOLD=0.7
# Ambiguous band [floor, threshold): the orchestrator may resample extra frames
# and ask the model to break the tie. Below the floor there is no signal worth it.
CLASSIFY_AMBIGUOUS_FLOOR=0.3
# Break ambiguous-band ties with a model classification (uses the summary endpoint).
CLASSIFY_USE_MODEL=true
# Bounded agentic resample around the failure window on ambiguous runs (0 disables).
MAX_RESAMPLE_RETRIES=2

# === Summary synthesis ===
# Text model that turns the fused video+audio timeline into the summary.
# Leave URL/MODEL blank to reuse the VLM endpoint (a vision-language model
# summarizes text fine) — no extra model server required.
SUMMARY_URL=
SUMMARY_MODEL=
SUMMARY_TIMEOUT_S=120.0
SUMMARY_MAX_TOKENS=1024

# === Transcription ===
# Drop transcript segments below this confidence (1 - no_speech_prob) to filter
# out Whisper's silence hallucinations (e.g. a phantom "Thank you." over silence).
ASR_MIN_CONFIDENCE=0.5

# === Upload and processing limits ===
MAX_UPLOAD_MB=512
MAX_DURATION_S=600
MAX_FRAMES_PER_MIN=30

# === Frame processing ===
# Frames are extracted at the low-res height; a suspected error frame with sparse
# OCR is re-decoded at the high-res height (uncompressed) for a focused re-read so
# tiny stack-trace text stays legible.
FRAME_LOWRES_HEIGHT=480
FRAME_HIGHRES_HEIGHT=1080

# === GIF preview ===
# Defaults for GET /v1/gif/{id} (and the get_video_gif MCP tool). The rendered
# window is capped at GIF_MAX_DURATION_S so the file stays small; per-request
# fps/width/start/end query params override these and are clamped to safe ranges.
GIF_FPS=10
GIF_WIDTH=640
GIF_MAX_DURATION_S=30.0

# === Storage ===
BUNDLE_DIR=./bug-reports
DATABASE_PATH=./bug-reports/jobs.db

# === Job queue ===
MAX_CONCURRENT_JOBS=2
JOB_TIMEOUT_S=1800

# === Logging ===
LOG_LEVEL=INFO
LOG_JSON=true

# === Security ===
CHROME_EXTENSION_ORIGIN=chrome-extension://localhost
REDACT_BEFORE_PROMPTS=true
